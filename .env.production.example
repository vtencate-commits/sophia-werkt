# =====================================================================
# Sophia Werkt - Production Environment Variables
# =====================================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
# Generate secrets with: openssl rand -base64 48
# =====================================================================

# ---- Public URLs (used for CORS, links in emails, OAuth callbacks) --
CLIENT_URL=https://sophiawerkt.nl
LAWYER_URL=https://kantoor.sophiawerkt.nl
ADMIN_URL=https://admin.sophiawerkt.nl
API_URL=https://api.sophiawerkt.nl

# ---- TLS / Caddy ----------------------------------------------------
# Email used by Let's Encrypt for certificate notifications.
ACME_EMAIL=ops@sophiawerkt.nl

# ---- PostgreSQL -----------------------------------------------------
POSTGRES_DB=sophia_werkt
POSTGRES_USER=sophia
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ---- Redis ----------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# ---- MinIO / S3 -----------------------------------------------------
MINIO_ROOT_USER=sophia_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
S3_BUCKET=sophia-werkt-documents
S3_REGION=eu-west-1

# ---- JWT ------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_to_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_long_random_string_at_least_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Anthropic Claude AI --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4000

# ---- Email (Resend / SMTP) ------------------------------------------
RESEND_API_KEY=re_...
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=noreply@sophiawerkt.nl

# ---- Security -------------------------------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ---- Logging --------------------------------------------------------
LOG_LEVEL=info
