# Database
DATABASE_URL=postgresql://sophia:password@localhost:5432/sophia_werkt

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-random-secure-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sophia-werkt-documents
S3_REGION=eu-west-1

# Email
SMTP_HOST=smtp.resend.com
SMTP_FROM=noreply@sophiawerkt.nl

# URLs
CLIENT_URL=http://localhost:3000
LAWYER_URL=http://localhost:3002
ADMIN_URL=http://localhost:3003
API_URL=http://localhost:3001

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
